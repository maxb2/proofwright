# Proofwright per-wiki config. Copy to your wiki root as `wiki.toml` and edit.
# All values shown are defaults; delete anything you don't override.

[paths]
raw = "raw/"            # immutable sources
wiki = "wiki/"          # LLM-owned pages
schema = "CLAUDE.md"    # conventions file; declared [[slugs]] must have page files
index = "wiki/index.md" # generated table of contents
# index_template = "index-hierarchical.md"  # Jinja2 template for the index; unset = flat list

[links]
style = "wikilink"      # wikilink = [[slug]] · markdown = [label](path.md) · both

[frontmatter]
required = ["title"]              # keys every page must have
types = { updated = "date" }      # key -> one of str|int|float|bool|list|date
tags = []                         # allowed tag vocabulary ([] = any)
tags_field = "tags"
grade_field = "grade"             # frontmatter key naming the relied-on source grade

[grades]
vocab = []              # fixed reliability grades ([] = grading not enforced)

[citation]
references = "section"           # how [n] maps to a source
references_heading = "References"
claim_policy = "paragraph"       # "paragraph" flags uncited prose; "off" disables coverage

[freshness]
recency_field = "updated"
stale_after_days = 180

[graph]
roots = ["index"]        # slugs allowed to have no inbound links
hub_min_inbound = 5
stub_max_chars = 200

[retrieval]
# `pw search "<query>"` fuses two deterministic streams with reciprocal rank fusion.
bm25_k1 = 1.5            # BM25 term-frequency saturation
bm25_b = 0.75           # BM25 document-length normalization
rrf_k = 60              # reciprocal rank fusion damping constant
graph_hops = 2          # how far graph expansion walks from the seed pages
graph_decay = 0.5       # per-hop score decay for graph candidates
seed_count = 10         # top BM25 hits used to seed graph expansion
candidate_limit = 50    # per-stream cap before fusion
top_n = 10              # results returned
min_token_len = 2       # tokens shorter than this are dropped
# LLM rerank is a bounded, injectable step (Reranker protocol); the default is a no-op.

# Optional third stream: dense vector similarity. Requires the extra:
#   pip install 'proofwright[vector]'
# [retrieval.vector]
# enabled = false                     # off by default; opt in here
# backend = "model2vec"               # static embeddings (numpy-only, deterministic)
# model = "minishlab/potion-retrieval-32M"  # HuggingFace id or local directory
# candidate_limit = 50                # per-stream cap before fusion

[checks]
fail_on = ["error"]      # severities that cause a nonzero exit code
disabled = []            # check ids to skip

[plugins]
modules = []             # dotted module paths exposing register(registry); the wiki root
                         # is on sys.path, so a wiki-local plugin file works by name
load_entry_points = true

# Plugins read their own config from arbitrary tables, exposed as cfg.extra. Example:
# a wiki that expresses provenance via a `sources:` frontmatter list (rather than the
# core [n]+References pattern) ships a plugin and configures it here:
#
#   [plugins]
#   modules = ["pw_provenance_plugin"]
#   [frontmatter_sources]
#   field = "sources"
#   require_for = ["book"]
